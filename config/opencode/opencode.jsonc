    },
    "bwen": {
      "name": "bwen",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://api.bwen.net/v1"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4"
        }
      }
    },
    "2capi": {
      "name": "2CAPI",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "https://2capi.com/v1"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4"
        },
        "claude-sonnet-4-6": {
          "name": "claude-sonnet-4-6"
        }
      }
    },
    "soeasy": {
      "name": "SoEasy",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://new-api.soeasy.space:3000/v1"
      },
      "models": {
        "gpt-5.4": {
          "name": "gpt-5.4"
        }
      }
    }
  },
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    },
    "build": {
      "options": {
        "store": false
      }
    },
    "plan": {
      "options": {
        "store": false,
        "disable": true
      }
    }
  },
}
