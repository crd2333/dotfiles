{
  "$schema": "https://opencode.ai/tui.json",
  "keybinds": {
    "terminal_suspend": "none",
    "app_exit": "ctrl+d,<leader>q",
    "input_clear": "none",
    "input_delete": "delete,shift+delete",
    "input_select_buffer_home": "alt+shift+left,alt+ctrl+left,shift+home",
    "input_select_buffer_end": "shift+alt+right,alt+ctrl+right,shift+end"
  }
}